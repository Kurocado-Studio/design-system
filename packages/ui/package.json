{
  "name": "@kurocado-studio/ui",
  "version": "0.0.0",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "license": "MIT",
  "files": [
    "dist/**"
  ],
  "scripts": {
    "build": "tsup src/index.tsx --format esm,cjs --dts --external react",
    "dev": "tsup src/index.tsx --format esm,cjs --watch --dts --external react",
    "lint": "eslint . --max-warnings 0",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist"
  },
  "devDependencies": {
    "@repo/eslint-config": "*",
    "@repo/typescript-config": "*",
    "@types/react": "^18.2.38",
    "@types/react-dom": "^18.2.17",
    "eslint": "^8.54.0",
    "react": "^18.2.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.2"
  },
  "dependencies": {
    "lucide-react": "^0.292.0",
    "postcss": "^8.4.31",
    "react-aria-components": "^1.0.0-rc.0",
    "tailwind-variants": "^0.1.18",
    "tailwindcss": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "tailwindcss-react-aria-components": "^1.1.2"
  },
  "publishConfig": {
    "access": "public",
    "@kurocado-studio/animation-client": "*",
    "@kurocado-studio/css-client": "*",
    "@kurocado-studio/ioc-client": "*",
    "@kurocado-studio/ui-core-config": "*",
    "@kurocado-studio/ui-primitives-client": "*",
    "@kurocado-studio/ui": "*",
    "@kurocado-studio/event-emitter-client": "*"
  }
}
